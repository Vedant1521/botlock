# Your Solana wallet address where USDC payments will land directly
WALLET_ADDRESS=YourSolanaWalletBase58AddressHere

# Solana network configuration (devnet or mainnet-beta)
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Supabase database configuration details
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# HMAC secrets (generate secure 32-byte hex strings using: openssl rand -hex 32)
PAYWALL_CHALLENGE_SECRET=your-32-byte-hex-challenge-secret
PAYWALL_AUTH_SECRET=your-32-byte-hex-auth-secret
PAYWALL_AUTH_DOMAIN=localhost:3000

# Optional: Solana fee payer secret key (base58 encoded or JSON array) if you want to auto-create USDC ATAs for recipients
FACILITATOR_FEE_PAYER_SECRET_KEY=

# Server configuration
PORT=3000
